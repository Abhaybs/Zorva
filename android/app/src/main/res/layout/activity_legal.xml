<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚖️ Legal Shield"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/accent_gold"
            android:layout_marginBottom="24dp" />

        <!-- Appeal Generator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appeal Generator"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etPlatform"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Platform name (e.g., Swiggy)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etWorkerId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Your Worker / Partner ID"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etDeactivationReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Reason cited for deactivation"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerateAppeal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generate Appeal Letter"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvAppealOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:background="@color/card_dark"
            android:padding="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Know Your Rights -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Know Your Rights"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvRightsGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>
</ScrollView>
